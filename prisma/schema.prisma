generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum OrgRole {
  admin
  member
}

enum TestItemType {
  message
  function_call
  function_call_output
  anthropic_system
  anthropic_message
}

enum Protocol {
  openai
  anthropic
}

enum ResponseLogStatus {
  success
  error
}

// ─── Models ──────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships OrgMembership[]
  invites     Invite[]
  orgTokens   OrgApiToken[]
  testSuites  TestSuite[]
  testRuns    TestRun[]

  @@map("organizations")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  oidcSubject String   @unique @map("oidc_subject")
  email       String
  name        String
  createdAt   DateTime @default(now()) @map("created_at")

  memberships OrgMembership[]
  personalTokens PersonalApiToken[]

  @@map("users")
}

model OrgMembership {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      OrgRole
  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_memberships")
}

model Invite {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("invites")
}

model PersonalApiToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String
  tokenHash   String    @unique @map("token_hash")
  tokenPrefix String    @map("token_prefix") @db.VarChar(12)
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_api_tokens")
}

model OrgApiToken {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  role        OrgRole
  tokenHash   String    @unique @map("token_hash")
  tokenPrefix String    @map("token_prefix") @db.VarChar(12)
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_api_tokens")
}

model TestSuite {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String
  description String?
  protocol    Protocol @default(openai)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tests Test[]
  responseLogs ResponseLog[]

  @@unique([orgId, name])
  @@map("test_suites")
}

model Test {
  id          String   @id @default(uuid()) @db.Uuid
  testSuiteId String   @map("test_suite_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  testSuite TestSuite  @relation(fields: [testSuiteId], references: [id], onDelete: Cascade)
  items     TestItem[]
  responseLogs ResponseLog[]

  @@unique([testSuiteId, name])
  @@map("tests")
}

model TestItem {
  id        String       @id @default(uuid()) @db.Uuid
  testId    String       @map("test_id") @db.Uuid
  position  Int
  type      TestItemType
  content   Json
  createdAt DateTime     @default(now()) @map("created_at")

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, position])
  @@index([testId, position])
  @@map("test_items")
}

model TestRun {
  id        String   @id @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String?
  commitSha String?  @map("commit_sha")
  branch    String?
  createdAt DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  responseLogs ResponseLog[]

  @@index([orgId, createdAt])
  @@map("test_runs")
}

model ResponseLog {
  id             String            @id @default(uuid()) @db.Uuid
  runId          String            @map("run_id") @db.Uuid
  status         ResponseLogStatus
  orgSlug        String            @map("org_slug")
  suiteName      String            @map("suite_name")
  model          String
  clientTestName String            @map("client_test_name")
  input          Json
  stream         Boolean           @default(false)
  suiteId        String?           @map("suite_id") @db.Uuid
  testId         String?           @map("test_id") @db.Uuid
  output         Json?
  responseId     String?           @map("response_id")
  errorCode      String?           @map("error_code")
  errorMessage   String?           @map("error_message")
  durationMs     Int               @map("duration_ms")
  createdAt      DateTime          @default(now()) @map("created_at")

  run   TestRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  suite TestSuite? @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  test  Test?      @relation(fields: [testId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt])
  @@index([runId, clientTestName])
  @@index([runId, testId])
  @@index([suiteId, createdAt])
  @@index([testId, createdAt])
  @@map("response_logs")
}
